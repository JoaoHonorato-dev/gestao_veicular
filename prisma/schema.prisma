// This file configures Prisma. Learn more: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Veículo cadastrado para monitoramento e controle operacional.
model Vehicle {
  id        Int      @id @default(autoincrement())
  plate     String   @unique
  brand     String
  model     String
  year      Int
  odometer  Int?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

//Inserção de tabela de usuario para controle e login no sistema
model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
